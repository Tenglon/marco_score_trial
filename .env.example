# OpenSearch
OPENSEARCH_URL=http://localhost:9200
OPENSEARCH_INDEX=openbeelden

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Frontend
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# LLM via litellm — default: local Ollama
LLM_PROVIDER=ollama
LLM_MODEL=ollama/llama3.2:3b-instruct
LLM_BASE_URL=http://localhost:11434

# To use an external OpenAI-compatible API instead, e.g.:
# LLM_PROVIDER=openai
# LLM_MODEL=deepseek/deepseek-chat
# LLM_API_KEY=sk-...

# spaCy NL model
SPACY_MODEL=nl_core_news_md

# CLIP model
CLIP_MODEL=ViT-B-32
CLIP_PRETRAINED=laion2b_s34b_b79k

# Data paths
DATA_DIR=./data
FIXTURES_DIR=./fixtures
